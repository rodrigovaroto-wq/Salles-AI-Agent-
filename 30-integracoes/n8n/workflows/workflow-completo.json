  "nodes": [
    {
      "id": "av-n1",
      "name": "WhatsApp IN",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        0,
        0
      ],
      "parameters": {
        "httpMethod": "POST",
        "path": "whatsapp-in",
        "responseMode": "onReceived",
        "options": {}
